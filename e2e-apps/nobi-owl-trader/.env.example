# NobiBot Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Exchange API Configuration
# Get your API keys from your exchange (e.g., Binance)
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET_KEY=your_secret_key_here

# Default exchange
# Use 'binanceus' for US users (binance.com is blocked in the US)
# Other options: kraken, coinbase, kucoin
DEFAULT_EXCHANGE=binanceus

# MongoDB Configuration (optional - for storing scan results)
MONGODB_URI=mongodb://localhost:27017/nobi
MONGODB_DB_NAME=nobi
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Trading Configuration
PAPER_TRADING=true
# Set to false for live trading (use with caution!)

# Risk Management
MAX_POSITION_SIZE=100
# Maximum position size in quote currency (e.g., USDT)

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
